package jamesstocktonj1:componentize-sdk;

world sdk {
  /// blobstore
  import wasi:blobstore/blobstore@0.2.0-draft;

  /// net/wasihttp
  import wasi:http/outgoing-handler@0.2.6;

  /// net/sockets
  include wasi:sockets/imports@0.2.6;
}

world http {
  export wasi:http/incoming-handler@0.2.6;
}

world cli {
  export wasi:cli/run@0.2.6;
}